{
  "name": "mineru-client",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "pino": "^9.0.0",
    "tslib": "^2.3.0",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.18.6",
    "@types/yauzl": "^2.10.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.0"
  }
}
