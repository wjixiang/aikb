# File Renderer Service 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# =============================================================================
# 数据库配置 (必需)
# =============================================================================

# PostgreSQL 连接字符串
# 格式: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/filerenderer

# =============================================================================
# S3/OSS 对象存储配置 (必需)
# =============================================================================

# S3 服务端点 (不含 protocol)
# 阿里云 OSS: oss-cn-hangzhou.aliyuncs.com
# Garage: 192.168.123.98:3900
# AWS S3: s3.amazonaws.com
S3_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# S3 访问密钥 ID
S3_ACCESS_KEY_ID=your-access-key-id

# S3 访问密钥 Secret
S3_ACCESS_KEY_SECRET=your-access-key-secret

# S3 存储桶名称
S3_BUCKET=agent-files

# S3 区域
# 阿里云: cn-hangzhou, cn-beijing, cn-shanghai 等
# AWS: us-east-1, eu-west-1 等
# Garage: garage
S3_REGION=cn-hangzhou

# 是否使用 path-style URL
# 阿里云 OSS: false
# Garage: true
# AWS S3: false
S3_FORCE_PATH_STYLE=false

# =============================================================================
# 服务器配置 (可选)
# =============================================================================

# 服务监听地址
SERVER_HOST=0.0.0.0

# 服务监听端口
SERVER_PORT=8000

# 是否启用热重载 (仅开发环境)
SERVER_RELOAD=false

# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
SERVER_LOG_LEVEL=INFO

# =============================================================================
# 分页配置 (可选)
# =============================================================================

# 默认每页字符数
DEFAULT_PAGE_SIZE=4000

# 语义分块大小
SEMANTIC_CHUNK_SIZE=2000

# 语义块重叠字符数
SEMANTIC_OVERLAP=200

# =============================================================================
# 文件转换配置 (可选)
# =============================================================================

# 最大文件大小 (字节), 默认 100MB
CONVERSION_MAX_FILE_SIZE=104857600

# 转换超时时间 (秒)
CONVERSION_TIMEOUT=300

# 是否启用 OCR
CONVERSION_ENABLE_OCR=true

# OCR 识别语言列表
CONVERSION_OCR_LANGUAGES=["eng", "chi_sim"]

# 是否启用表格识别
CONVERSION_ENABLE_TABLE_EXTRACTION=true

# 是否启用图片提取
CONVERSION_ENABLE_IMAGE_EXTRACTION=false

# 并发转换工作线程数
CONVERSION_MAX_WORKERS=4

# 是否启用转换缓存
CONVERSION_ENABLE_CACHE=true

# 缓存有效期 (小时), 默认 7 天
CONVERSION_CACHE_TTL_HOURS=168

# =============================================================================
# 应用配置 (可选)
# =============================================================================

# 调试模式
DEBUG=false

# 应用名称
APP_NAME=file-renderer

# 应用版本
APP_VERSION=0.1.0
