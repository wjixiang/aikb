// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ExpertInstance 已废弃，使用 AgentInstance 替代
// model ExpertInstance { ... }

// Phase 2: Memory Persistence
model AgentMemory {
  id              String   @id @default(uuid())
  instanceId      String   @unique
  instance        AgentInstance @relation(fields: [instanceId], references: [instanceId], onDelete: Cascade)

  messages        Json     // ApiMessage[]
  workspaceContexts Json?  // WorkspaceContextEntry[]
  config          Json?    // MemoryModuleConfig

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 3: Component State Persistence
model ComponentState {
  id              String   @id @default(uuid())
  instanceId      String
  instance        AgentInstance @relation(fields: [instanceId], references: [instanceId], onDelete: Cascade)

  componentId     String
  stateData       Json     // 组件特定状态

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([instanceId, componentId])
}

// AgentContainer 实例元数据持久化
model AgentInstance {
  id              String   @id @default(uuid())
  instanceId      String   @unique  // AgentContainer 的 instanceId

  // 状态信息
  status          String   @default("idle") // idle/running/completed/aborted
  abortReason     String?  // user/system/error/timeout/manual
  abortSource     String?

  // 配置快照
  config          Json?    // UnifiedAgentConfig 序列化

  // AgentMetadata 字段 (用于 AgentRegistry)
  name            String?   // Agent 友好名称
  agentType       String?   // Agent 类型标识 (如 'pubmed-retrieve')

  // 统计信息
  totalTokensIn   Int      @default(0)
  totalTokensOut  Int      @default(0)
  totalCost       Float    @default(0)

  // 工具使用统计
  toolUsage       Json? // Record<string, { attempts: number; failures: number }>

  // 错误追踪
  consecutiveMistakeCount Int @default(0)
  collectedErrors Json? // string[]

  // 导出结果
  exportResult    Json?    // Record<string, ExportResult>

  // 时间戳
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  // Relations
  memory          AgentMemory?
  componentStates ComponentState[]

  @@index([instanceId])
  @@index([status])
  @@index([agentType])
}


