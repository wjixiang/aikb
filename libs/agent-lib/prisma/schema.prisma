// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ExpertInstance 已废弃，使用 AgentSession 替代
// model ExpertInstance { ... }

model AgentSession {
  id              String   @id @default(uuid())
  instanceId      String   // 关联 AgentInstance.instanceId

  // 状态信息
  status          String   @default("idle") // idle/running/completed/aborted
  abortReason     String?
  abortSource     String? // user/system/error/timeout/manual

  // 配置 (JSON)
  config          Json? // AgentConfig 序列化

  // 统计信息
  totalTokensIn   Int      @default(0)
  totalTokensOut  Int      @default(0)
  totalCost       Float    @default(0)

  // 工具使用统计
  toolUsage       Json? // Record<string, { attempts: number; failures: number }>

  // 错误追踪
  consecutiveMistakeCount Int @default(0)
  collectedErrors Json? // string[]

  // 导出结果 (Phase 4: Result Export Persistence)
  exportResult    Json?    // Record<string, ExportResult>

  // 时间戳
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  // Relations
  instance        AgentInstance @relation(fields: [instanceId], references: [instanceId], onDelete: Cascade)
  componentStates ComponentState[]

  @@unique([instanceId])  // 一个 AgentInstance 只有一条 Session 记录
  @@index([status])
  @@index([createdAt])
}

// Phase 2: Memory Persistence
model AgentMemory {
  id              String   @id @default(uuid())
  instanceId      String   @unique
  instance        AgentInstance @relation(fields: [instanceId], references: [instanceId], onDelete: Cascade)

  messages        Json     // ApiMessage[]
  workspaceContexts Json?  // WorkspaceContextEntry[]
  config          Json?    // MemoryModuleConfig

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 3: Component State Persistence
model ComponentState {
  id              String   @id @default(uuid())
  sessionId       String
  session         AgentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  componentId     String
  stateData       Json     // 组件特定状态

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sessionId, componentId])
}

// AgentContainer 实例元数据持久化
model AgentInstance {
  id              String   @id @default(uuid())
  instanceId      String   @unique  // AgentContainer 的 instanceId

  // 状态信息
  status          String   @default("idle") // idle/running/completed/aborted

  // 配置快照
  config          Json?    // UnifiedAgentConfig 序列化

  // AgentMetadata 字段 (用于 AgentRegistry)
  name            String?   // Agent 友好名称
  agentType       String?   // Agent 类型标识 (如 'pubmed-retrieve')

  // 时间戳
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  completedAt     DateTime?

  // Relations
  sessions        AgentSession[]
  memory          AgentMemory?

  @@index([instanceId])
  @@index([status])
  @@index([agentType])
}

// Runtime Task - 中心任务队列
model RuntimeTask {
  id              String   @id @default(uuid())
  taskId          String   @unique

  // 任务信息
  description     String
  input           Json?
  priority        String   @default("normal")  // low/normal/high/urgent
  status          String   @default("pending") // pending/processing/completed/failed

  // 路由信息 (直接指定目标 Agent)
  targetInstanceId String

  // 结果 - 存储 workspace.exportResult() 的输出
  output          Json?
  error           String?

  // 时间戳
  createdAt       DateTime @default(now())
  startedAt       DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?

  @@index([status])
  @@index([targetInstanceId])
  @@index([createdAt])
}

/// A2A conversation log — event-sourced from TopologyEvent
model A2AConversationLog {
  id              String   @id @default(uuid())
  conversationId  String   @unique

  /// Source agent instance ID
  fromInstanceId  String
  /// Target agent instance ID
  toInstanceId    String

  /// pending | acknowledged | completed | failed | timeout
  status          String   @default("pending")

  /// Optional link to RuntimeTask
  runtimeTaskId   String?

  error           String?

  createdAt       DateTime @default(now())
  ackAt           DateTime?
  completedAt     DateTime?

  @@index([fromInstanceId, toInstanceId])
  @@index([status])
  @@index([createdAt])
}
