{
  "name": "agent-lib",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "expert-cli": "./src/core/expert/cli/index.ts",
    "agent-cli": "./src/cli/index.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/src/core/index.d.ts",
      "default": "./dist/src/core/index.js"
    },
    "./components": {
      "types": "./dist/src/components/index.d.ts",
      "default": "./dist/src/components/index.js"
    },
    "./components/ui": {
      "types": "./dist/src/components/ui/index.d.ts",
      "default": "./dist/src/components/ui/index.js"
    },
    "./components/ui/index.js": {
      "types": "./dist/src/components/ui/index.d.ts",
      "default": "./dist/src/components/ui/index.js"
    },
    "./components/utils": {
      "types": "./dist/src/components/utils/index.d.ts",
      "default": "./dist/src/components/utils/index.js"
    },
    "./components/utils/index.js": {
      "types": "./dist/src/components/utils/index.d.ts",
      "default": "./dist/src/components/utils/index.js"
    },
    "./multi-agent": {
      "types": "./dist/src/multi-agent/index.d.ts",
      "default": "./dist/src/multi-agent/index.js"
    },
    "./core/agent": {
      "types": "./dist/src/core/agent/agent.d.ts",
      "default": "./dist/src/core/agent/agent.js"
    }
  },
  "scripts": {
    "test": "vitest --config vite.config.mts",
    "test:integrated": "vitest --config vite.config.integrated.mts",
    "run:article-retrieval": "vitest run --config vite.config.mts scripts/article-retrieval-skill.ts",
    "build": "tsup",
    "build:watch": "vite build --watch",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit",
    "expert:list": "npx tsx src/core/expert/cli/index.ts list",
    "expert:validate": "npx tsx src/core/expert/cli/index.ts validate",
    "expert:show": "npx tsx src/core/expert/cli/index.ts show",
    "expert:new": "npx tsx src/core/expert/cli/index.ts new",
    "expert:demo": "npx tsx src/core/expert/cli/index.ts demo",
    "expert:test": "npx tsx src/core/expert/cli/index.ts test",
    "expert:test:run": "npx tsx src/core/expert/cli/index.ts test run",
    "expert:test:run:ts": "npx tsx src/core/expert/cli/index.ts test run:ts",
    "expert:test:init": "npx tsx src/core/expert/cli/index.ts test init",
    "expert:test:list": "npx tsx src/core/expert/cli/index.ts test list",
    "agent:runtime:start": "npx tsx src/cli/index.ts runtime start",
    "agent:runtime:stop": "npx tsx src/cli/index.ts runtime stop",
    "agent:runtime:status": "npx tsx src/cli/index.ts runtime status",
    "agent:test:basic": "npx tsx src/cli/index.ts test basic",
    "agent:test:a2a": "npx tsx src/cli/index.ts test a2a",
    "agent:test:redis": "npx tsx src/cli/index.ts test redis",
    "agent:monitor:runtime": "npx tsx src/cli/index.ts monitor runtime"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@apollo/client": "^3.8.0",
    "@aws-sdk/client-s3": "^3.901.0",
    "@lmstudio/sdk": "^1.5.0",
    "@nestjs/common": "^10.0.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@shared/logger": "workspace:*",
    "agent-soul-hub": "workspace:*",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "graphql": "^16.8.0",
    "inversify": "^7.11.0",
    "llm-api-client": "workspace:*",
    "openai": "^5.23.2",
    "ora": "^8.0.0",
    "persistence-lib": "workspace:*",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "tiktoken": "^1.0.22",
    "tslib": "^2.3.0",
    "valtio": "^2.0.0",
    "winston": "^3.17.0",
    "winston-transport": "^4.9.0",
    "yaml": "^2.7.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.0.0",
    "esbuild": "^0.27.3",
    "prisma": "^7.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vite": "^6.4.1",
    "vitest": "^4.0.0"
  }
}
