{
  "name": "pwas",
  "title": "pwas",
  "summary": "pwas app use spark",
  "dxapi": "1.0.0",
  "version": "0.0.1",
  "inputSpec": [
    {
      "name": "dataset_record",
      "class": "applet",
      "optional": true,
      "help": ""
    },
    {
      "name": "entity_name",
      "class": "string",
      "optional": true,
      "help": ""
    }
  ],
  "outputSpec": [],
  "runSpec": {
    "timeoutPolicy": {
      "*": {
        "hours": 4
      }
    },
    "interpreter": "python3",
    "file": "src/pwas.py",
    "distribution": "Ubuntu",
    "release": "24.04",
    "version": "0"
  },
  "access": {
    "network": [
      "*"
    ],
    "project": "CONTRIBUTE"
  },
  "regionalOptions": {
    "aws:us-east-1": {
      "systemRequirements": {
        "*": {
          "instanceType": "mem1_ssd1_v2_x2",
          "clusterSpec": {
            "type": "dxspark",
            "version": "3.5.2",
            "initialInstanceCount": "1",
            "ports": "9500, 9700-9750"
          }
        }
      }
    }
  }
}
