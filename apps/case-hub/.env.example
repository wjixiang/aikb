# ==================== Application Configuration ====================
# 运行环境: development, production, test
NODE_ENV=development

# 服务端口
PORT=3000

# 服务主机
HOST=0.0.0.0

# ==================== Database Configuration ====================
# PostgreSQL 数据库连接字符串
DATABASE_URL=postgresql://user:password@localhost:5432/case_hub?schema=public

# 数据库连接池大小
DATABASE_POOL_SIZE=10

# 数据库连接超时时间 (毫秒)
DATABASE_TIMEOUT=30000

# ==================== Logging Configuration ====================
# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# 日志格式: json, pretty
LOG_FORMAT=pretty

# ==================== Storage Configuration ====================
# 存储类型: local, s3, minio
STORAGE_TYPE=local

# 本地存储路径 (当 STORAGE_TYPE=local 时使用)
STORAGE_PATH=./storage/cases

# 最大文件大小 (字节, 默认 10MB)
STORAGE_MAX_SIZE=10485760

# S3/MinIO 配置 (当 STORAGE_TYPE=s3 或 minio 时使用)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=us-east-1
# S3_BUCKET=case-hub
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ==================== API Configuration ====================
# API 前缀
API_PREFIX=api

# API 版本
API_VERSION=v1

# ==================== Rate Limiting Configuration ====================
# 是否启用限流
RATE_LIMIT_ENABLED=true

# 限流时间窗口 (毫秒)
RATE_LIMIT_WINDOW_MS=60000

# 最大请求数
RATE_LIMIT_MAX=100

# ==================== Cache Configuration ====================
# 是否启用缓存
CACHE_ENABLED=true

# 默认缓存 TTL (秒)
CACHE_TTL=300

# ==================== CORS Configuration ====================
# 允许的源 (* 表示允许所有)
CORS_ORIGIN=*

# 是否允许凭证
CORS_CREDENTIALS=true

# ==================== LLM API Keys ====================
# Minimax API Key
MINIMAX_API_KEY=your-minimax-api-key

# OpenAI API Key (可选)
# OPENAI_API_KEY=your-openai-api-key

# GLM API Key (可选)
# GLM_API_KEY=your-glm-api-key
