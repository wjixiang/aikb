// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client-js"
  output       = "../generated/prisma"
  moduleFormat = "esm"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
}

model ReviewTask {
  id        String         @id @unique @default(uuid())
  taskInput String
  section   String         @default("epidemiology")
  progress  TaskProgress[]
  searches  ArticleSearch[]
}

model TaskProgress {
  id           String      @id @unique @default(uuid())
  done         String
  log          String
  ts           DateTime
  reviewTask   ReviewTask? @relation(fields: [reviewTaskId], references: [id])
  reviewTaskId String?
}

model ArticleSearch {
  id             String                @id @default(uuid())
  taskId         String
  task           ReviewTask            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  searchTerm     String
  totalResults   Int?
  filters        String[]
  sort           String
  dateRange      String
  iteration      Int
  final          Boolean                @default(false)
  articleResults ArticleSearchResult[]

  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([taskId])
}

model ArticleSearchResult {
  id              String        @id @default(uuid())
  searchId        String
  search          ArticleSearch @relation(fields: [searchId], references: [id], onDelete: Cascade)
  pmid            String
  title           String
  authors         String
  journalCitation String
  snippet         String?
  doi             String?
  position        Int?
  note            String?
  embedding       ArticleEmbedding?

  createdAt       DateTime      @default(now())

  @@unique([searchId, pmid])
  @@index([pmid])
  @@index([searchId])
}

model ArticleEmbedding {
  id        String              @id @default(uuid())
  resultId  String              @unique
  result    ArticleSearchResult @relation(fields: [resultId], references: [id], onDelete: Cascade)

  provider  String
  model     String
  dimension Int
  text      String
  vector    Unsupported("vector")?
  isActive  Boolean             @default(true)

  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([provider, model])
}
