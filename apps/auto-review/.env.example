# Server Configuration
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/auto_review

# LLM API (for literature summary)
LLM_API_URL=https://api.minimaxi.com/anthropic/v1/messages
MINIMAX_API_KEY=your_minimax_api_key_here

# MinerU (for PDF extraction)
MINERU_TOKEN=your_mineru_token_here
MINERU_DOWNLOAD_DIR=./mineru-downloads
FILE_RENDERER_URL=http://localhost:8000

# File Uploads
UPLOADS_DIR=./uploads
MAX_FILE_SIZE=104857600

# CORS
CORS_ORIGIN=*
CORS_CREDENTIALS=false

# Swagger Documentation
SWAGGER_ENABLED=true

# Logging
LOG_LEVEL=info
