# BibMax Document Processing Service Configuration

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
SERVER_LOG_LEVEL=INFO
SERVER_WORKERS=1

# Application Configuration
APP_NAME=BibMax Document Processing Service
APP_VERSION=1.0.0
DEBUG=false

# Conversion Configuration
CONVERSION_MAX_FILE_SIZE=104857600
CONVERSION_TIMEOUT=300
CONVERSION_ENABLE_OCR=true
CONVERSION_OCR_LANGUAGES=["eng", "chi_sim"]
CONVERSION_ENABLE_TABLE_EXTRACTION=true
CONVERSION_ENABLE_CACHE=true

# Chunking Configuration
CHUNKING_DEFAULT_CHUNK_SIZE=1000
CHUNKING_MAX_CHUNK_SIZE=2000
CHUNKING_CHUNK_OVERLAP=200
CHUNKING_SEMANTIC_CHUNK_SIZE=2000
CHUNKING_SEMANTIC_OVERLAP=200

# Database Configuration (optional, for future use)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bibmax_docs
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10

# Storage Configuration
# STORAGE_PATH=/tmp/bibmax_documents
