DATABASE_URL=postgresql://user:password@localhost:5432/bib_max
PORT=3000
APP_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# S3 Storage (AWS S3 / MinIO / Cloudflare R2)
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=bib-max
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=false
S3_PUBLIC_URL=

# LLM Clients (JSON array)
# Each entry: name (optional), provider, apiKey, modelId, baseUrl (optional)
LLM_CLIENTS='[{"name":"default","provider":"zai","apiKey":"your-key","modelId":"glm-4-flash"}]'

# File Renderer Service (PDF to Markdown conversion)
FILE_RENDERER_URL=http://localhost:8001/api/v1
FILE_RENDERER_TIMEOUT=300000
FILE_RENDERER_POLL_INTERVAL=3000
