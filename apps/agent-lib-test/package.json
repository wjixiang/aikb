{
  "name": "agent-lib-test",
  "version": "1.0.0",
  "description": "Test app for agent-lib Expert CLI",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:expert": "vitest run src/expert-demo.test.ts",
    "test:expert-cli": "npx tsx src/test-expert-cli.ts",
    "expert:new": "npx tsx ../../libs/agent-lib/src/expert/cli/index.ts new",
    "expert:list": "npx tsx ../../libs/agent-lib/src/expert/cli/index.ts list",
    "expert:validate": "npx tsx ../../libs/agent-lib/src/expert/cli/index.ts validate",
    "expert:show": "npx tsx ../../libs/agent-lib/src/expert/cli/index.ts show",
    "expert:demo": "npx tsx ../../libs/agent-lib/src/expert/cli/index.ts demo",
    "expert:test": "npx tsx ../../libs/agent-lib/src/expert/cli/index.ts test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.7.0",
  "dependencies": {
    "agent-lib": "workspace:*"
  },
  "devDependencies": {
    "@swc-node/register": "~1.9.1",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^1.6.1"
