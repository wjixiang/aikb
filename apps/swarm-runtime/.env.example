# ========================
# LLM Provider
# ========================
# Supported: openai, anthropic, minimax, moonshot, ollama, lmstudio, zai
API_PROVIDER=openai
API_MODEL_ID=gpt-4
API_TIMEOUT=120000

# ========================
# API Keys
# ========================
OPENAI_API_KEY=your_openai_api_key
# GLM_API_KEY=your_glm_api_key
# KIMI_API_KEY=your_kimi_api_key
# MINIMAX_API_KEY=your_minimax_api_key

# ========================
# Database (Prisma)
# ========================
AGENT_DATABASE_URL=postgresql://user:password@localhost:5432/agent?schema=public

# ========================
# Message Bus (Redis)
# ========================
# Options: memory (default) | redis
A2A_MESSAGE_BUS_MODE=memory
# A2A_REDIS_URL=redis://localhost:6379
# A2A_REDIS_PASSWORD=
# A2A_REDIS_HOST=localhost
# A2A_REDIS_PORT=6379
# A2A_REDIS_DB=0

# ========================
# Server
# ========================
# SERVER_ID=swarm-xxx
# SERVER_HOST=0.0.0.0
# PORT=9400
# LOG_LEVEL=info
# MAX_AGENTS=50

# ========================
# Runtime Control API
# ========================
# SWARM_REST_BASE_URL=http://localhost:9400
# SWARM_API_KEY=optional-api-key

# ========================
# Topology Timeouts
# ========================
# A2A_ACK_TIMEOUT=5000
# A2A_MAX_RETRIES=3
