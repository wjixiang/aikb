// Mailbox Database Schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Mail message stored in the database
model MailMessage {
  // Primary key
  messageId String @id @default(cuid())

  // Address fields (email-style: user@domain)
  from String
  to   String
  cc   String[]
  bcc  String[]

  // Content
  subject String
  body    String?
  payload Json?

  // Attachments (S3 keys)
  attachments String[]

  // Metadata
  priority String  @default("normal") // low, normal, high, urgent
  taskId   String?

  // Threading
  inReplyTo  String?
  references String[]

  // Status
  read    Boolean @default(false)
  starred Boolean @default(false)
  deleted Boolean @default(false)

  // Timestamps
  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for common queries
  @@index([to])
  @@index([from])
  @@index([sentAt])
  @@index([taskId])
}

// Registered address (expert or mc)
model RegisteredAddress {
  // Address (email-style: user@domain)
  address String @id

  // Address type info
  user   String
  domain String?

  // Status
  active Boolean @default(true)

  // Registration time
  registeredAt DateTime @default(now())
  lastActiveAt DateTime @updatedAt

  // Statistics
  totalReceived Int @default(0)
  totalSent     Int @default(0)

  @@unique([user, domain])
}
