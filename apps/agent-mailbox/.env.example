# Agent Mailbox Environment Configuration

# ============================================
# Server Configuration
# ============================================

# Server port (default: 3000)
PORT=3000

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Log level: debug, info, warn, error (default: info in production, debug in development)
LOG_LEVEL=info

# Enable request logging (default: true in development, false in production)
REQUEST_LOGGING=true

# ============================================
# Database Configuration
# ============================================

# PostgreSQL connection URL (required)
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://admin:fl5ox03@localhost:5432/agent_mailbox?schema=public"

# Enable query logging (default: true in development, false in production)
DB_LOG_QUERIES=false

# Database connection pool size (default: 10)
DB_POOL_SIZE=10

# ============================================
# CORS Configuration
# ============================================

# Allowed origins (default: * for all origins)
# Use comma-separated values for multiple origins: "http://localhost:3000,http://localhost:3001"
CORS_ORIGIN=*

# Allowed HTTP methods (default: GET,POST,PUT,DELETE,PATCH,OPTIONS)
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS

# Allowed headers (default: Content-Type,Authorization)
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# Allow credentials (default: false)
CORS_CREDENTIALS=false

# ============================================
# WebSocket Configuration
# ============================================

# Enable WebSocket support (default: true)
WS_ENABLED=true

# Ping interval in milliseconds (default: 30000 = 30 seconds)
WS_PING_INTERVAL=30000

# Connection timeout in milliseconds (default: 5000 = 5 seconds)
WS_CONNECTION_TIMEOUT=5000

# ============================================
# Rate Limiting Configuration
# ============================================

# Enable rate limiting (default: true in production, false in development)
RATE_LIMIT_ENABLED=false

# Max requests per window (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# Time window in milliseconds (default: 60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# Security Configuration
# ============================================

# Enable Helmet security headers (default: true in production, false in development)
SECURITY_ENABLE_HELMET=false

# API key for authentication (optional)
# API_KEY=your-secret-api-key

# JWT secret for token verification (optional)
# JWT_SECRET=your-jwt-secret

# ============================================
# Environment
# ============================================

# Environment name: development, production, test
NODE_ENV=development
